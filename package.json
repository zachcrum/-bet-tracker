{
  "name": "nba-multi-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
